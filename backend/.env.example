# Backend environment variables for deployment
# Copy this file to .env and fill in the values before deploying.

NODE_ENV=production
PORT=3000

# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.g9p9ys5.mongodb.net/site_star_mousse?retryWrites=true&w=majority
# For legacy compatiblity, the project also reads url_Mongodb:
# url_Mongodb=mongodb+srv://<username>:<password>@cluster0.g9p9ys5.mongodb.net/site_star_mousse?retryWrites=true&w=majority

SESSION_SECRET=replace-with-a-strong-secret

# Frontend URL for CORS and client-origin validation
FRONTEND_URL=https://site-star-mousse.vercel.app
CORS_ORIGINS=https://site-star-mousse.vercel.app
CLIENT_URL=https://site-star-mousse.vercel.app
