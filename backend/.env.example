# Backend — copier vers .env à la racine
PORT=3000
NODE_ENV=development

# MongoDB (obligatoire pour l'API)
# Local :
url_Mongodb=mongodb://127.0.0.1:27017/site_star_mousse
# Atlas (exemple) :
# url_Mongodb=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/site_star_mousse?retryWrites=true&w=majority

# Si Atlas échoue en dev, repli automatique vers MongoDB local (si installé)
MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/site_star_mousse

# JWT
JWT_SECRET=votre-cle-secrete-jwt
JWT_SECRET_KEY=votre-cle-secrete-jwt

# CORS — ports Vite (5173, 5174, …)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Frontend (dev : laisser /api pour le proxy Vite)
VITE_API_URL=/api
VITE_API_PROXY=http://localhost:3000
