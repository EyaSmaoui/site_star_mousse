# Example environment variables for the Chatbot Flask microservice
# Copy to .env and fill values before deploying

# Flask config
FLASK_APP=app.py
FLASK_ENV=production

# Sentence transformer model name (HuggingFace model)
SENTENCE_MODEL=all-MiniLM-L6-v2

# Similarity threshold between 0 and 1
SIMILARITY_THRESHOLD=0.75

# Service port
PORT=5001

# In production, run behind gunicorn and set sockets/host accordingly
# GUNICORN_CMD_ARGS=--workers 2 --bind 0.0.0.0:5001
