import { useState, useEffect } from "react";
import { useNavigate } from "react-router-dom";
import { toast } from "react-toastify";
import EmployeeSidebar from "./EmployeeSidebar";
import { hasAccess, ROLES } from "../../utils/authUtils";
import { getAllOrders, updateOrder } from "../../services/apiOrder";

const STATUS_OPTIONS = ["En préparation", "Expédiée", "Livrée"];

export default function EmployeeOrders() {
  const navigate = useNavigate();
  const [orders, setOrders] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const token = localStorage.getItem("token");
    const userData = localStorage.getItem("user");

    if (!token || !userData) {
      toast.error("Veuillez vous connecter");
      navigate("/login/employee");
      return;
    }

    const parsedUser = JSON.parse(userData);
    if (!hasAccess(parsedUser, [ROLES.MANAGER, ROLES.EMPLOYEE, "employeur"])) {
      toast.error("Accès non autorisé");
      navigate("/login");
      return;
    }

    fetchOrders();
  }, [navigate]);

  const fetchOrders = async () => {
    try {
      const data = await getAllOrders();
      setOrders(data);
    } catch (error) {
      toast.error("Erreur lors du chargement des commandes");
    } finally {
      setLoading(false);
    }
  };

  const updateStatus = async (orderId, nextStatus) => {
    try {
      await updateOrder(orderId, { status: nextStatus });
      setOrders((current) =>
        current.map((order) =>
          order._id === orderId ? { ...order, status: nextStatus } : order
        )
      );
      toast.success(`Statut de la commande mis à jour : ${nextStatus}`);
    } catch (error) {
      toast.error("Erreur lors de la mise à jour du statut");
    }
  };

  const formatDate = (dateString) => {
    return new Date(dateString).toLocaleDateString('fr-FR');
  };

  const getStatusStats = () => {
    const stats = { nouvelles: 0, preparation: 0, livraisons: 0 };
    orders.forEach(order => {
      if (order.status === "En préparation") stats.preparation++;
      else if (order.status === "Livrée") stats.livraisons++;
      else if (order.status === "Confirmée" || !order.status) stats.nouvelles++;
    });
    return stats;
  };

  const stats = getStatusStats();

  return (
    <div style={styles.wrapper}>
      <EmployeeSidebar />
      <main style={styles.main}>
        <div style={styles.header}>
          <div>
            <p style={styles.breadcrumb}>Employé / Commandes</p>
            <h1 style={styles.title}>Gestion des commandes</h1>
            <p style={styles.subtitle}>Suivre les nouvelles commandes et mettre à jour les statuts en temps réel.</p>
          </div>
          <button style={styles.primaryButton} onClick={() => navigate("/employer/dashboard")}>Retour au tableau de bord</button>
        </div>

        <section style={styles.cardsRow}>
          <div style={styles.statCard}><strong>{stats.nouvelles}</strong><span>Nouvelles commandes</span></div>
          <div style={styles.statCard}><strong>{stats.preparation}</strong><span>En préparation</span></div>
          <div style={styles.statCard}><strong>{stats.livraisons}</strong><span>Livraisons aujourd’hui</span></div>
        </section>

        {loading ? (
          <div style={styles.loading}>Chargement...</div>
        ) : (
          <div style={styles.tableCard}>
            <div style={styles.tableHeader}>Dernières commandes</div>
            <table style={styles.table}>
              <thead>
                <tr>
                  <th>Référence</th>
                  <th>Client</th>
                  <th>Montant</th>
                  <th>Statut</th>
                  <th>Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {orders.map((order) => (
                  <tr key={order._id}>
                    <td>#{order._id.slice(-4)}</td>
                    <td>{order.customerName || "Client inconnu"}</td>
                    <td>{order.total ? `${order.total} DT` : "N/A"}</td>
                    <td>{order.status || "Confirmée"}</td>
                    <td>{formatDate(order.createdAt)}</td>
                    <td>
                      <select
                        value={order.status || "Confirmée"}
                        onChange={(e) => updateStatus(order._id, e.target.value)}
                        style={styles.select}
                      >
                        {STATUS_OPTIONS.map((option) => (
                          <option key={option} value={option}>{option}</option>
                        ))}
                      </select>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </main>
    </div>
  );
}

  return (
    <div style={styles.wrapper}>
      <EmployeeSidebar />
      <main style={styles.main}>
        <div style={styles.header}>
          <div>
            <p style={styles.breadcrumb}>Employé / Commandes</p>
            <h1 style={styles.title}>Gestion des commandes</h1>
            <p style={styles.subtitle}>Suivre les nouvelles commandes et mettre à jour les statuts en temps réel.</p>
          </div>
          <button style={styles.primaryButton} onClick={() => navigate("/employer/dashboard")}>Retour au tableau de bord</button>
        </div>

        <section style={styles.cardsRow}>
          <div style={styles.statCard}><strong>5</strong><span>Nouvelles commandes</span></div>
          <div style={styles.statCard}><strong>3</strong><span>En préparation</span></div>
          <div style={styles.statCard}><strong>2</strong><span>Livraisons aujourd’hui</span></div>
        </section>

        {loading ? (
          <div style={styles.loading}>Chargement...</div>
        ) : (
          <div style={styles.tableCard}>
            <div style={styles.tableHeader}>Dernières commandes</div>
            <table style={styles.table}>
              <thead>
                <tr>
                  <th>Référence</th>
                  <th>Client</th>
                  <th>Montant</th>
                  <th>Statut</th>
                  <th>Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {orders.map((order) => (
                  <tr key={order.id}>
                    <td>{order.id}</td>
                    <td>{order.customer}</td>
                    <td>{order.amount}</td>
                    <td>{order.status}</td>
                    <td>{order.date}</td>
                    <td>
                      <select
                        value={order.status}
                        onChange={(e) => updateStatus(order.id, e.target.value)}
                        style={styles.select}
                      >
                        {STATUS_OPTIONS.map((option) => (
                          <option key={option} value={option}>{option}</option>
                        ))}
                      </select>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </main>
    </div>
  );
}

const styles = {
  wrapper: { display: "flex", minHeight: "100vh", background: "#f5f0e8", fontFamily: "'DM Sans', sans-serif" },
  main: { marginLeft: 260, flex: 1, padding: "32px 34px 48px" },
  header: { display: "flex", justifyContent: "space-between", alignItems: "flex-start", gap: 20, marginBottom: 24 },
  breadcrumb: { margin: 0, fontSize: 12, color: "#8f7a63", textTransform: "uppercase", letterSpacing: ".12em" },
  title: { margin: "8px 0 8px", fontSize: 32, fontWeight: 800, color: "#1a1714" },
  subtitle: { margin: 0, fontSize: 14, color: "#5f5246", maxWidth: 580 },
  primaryButton: { background: "#c8651a", border: "none", color: "white", borderRadius: 14, padding: "12px 18px", cursor: "pointer", fontWeight: 700 },
  cardsRow: { display: "grid", gridTemplateColumns: "repeat(3, minmax(0, 1fr))", gap: 16, marginBottom: 26 },
  statCard: { background: "#fff", borderRadius: 18, border: "1px solid #e7ddd1", padding: 24, boxShadow: "0 10px 35px rgba(0,0,0,0.02)", display: "flex", flexDirection: "column", gap: 10, fontWeight: 700, color: "#1f1a17" },
  tableCard: { background: "#fff", borderRadius: 20, padding: 20, border: "1px solid #ece2d7" },
  tableHeader: { fontSize: 16, fontWeight: 700, marginBottom: 16, color: "#3f352e" },
  table: { width: "100%", borderCollapse: "collapse", fontSize: 14, color: "#4b433d" },
  select: { width: "100%", padding: "8px 10px", borderRadius: 10, border: "1px solid #c6b8a7", background: "#fff", outline: "none" },
  loading: { padding: 28, color: "#6e5f52" },
};
}

const styles = {
  wrapper: { display: 'flex', minHeight: '100vh', background: '#f5f0e8', fontFamily: ''DM Sans', sans-serif' },
  main: { marginLeft: 260, flex: 1, padding: '32px 34px 48px' },
  header: { display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', gap: 20, marginBottom: 24 },
  breadcrumb: { margin: 0, fontSize: 12, color: '#8f7a63', textTransform: 'uppercase', letterSpacing: '.12em' },
  title: { margin: '8px 0 8px', fontSize: 32, fontWeight: 800, color: '#1a1714' },
  subtitle: { margin: 0, fontSize: 14, color: '#5f5246', maxWidth: 580 },
  primaryButton: { background: '#c8651a', border: 'none', color: 'white', borderRadius: 14, padding: '12px 18px', cursor: 'pointer', fontWeight: 700 },
  cardsRow: { display: 'grid', gridTemplateColumns: 'repeat(3, minmax(0, 1fr))', gap: 16, marginBottom: 26 },
  statCard: { background: '#fff', borderRadius: 18, border: '1px solid #e7ddd1', padding: 24, boxShadow: '0 10px 35px rgba(0,0,0,0.02)', display: 'flex', flexDirection: 'column', gap: 10, fontWeight: 700, color: '#1f1a17' },
  tableCard: { background: '#fff', borderRadius: 20, padding: 20, border: '1px solid #ece2d7' },
  tableHeader: { fontSize: 16, fontWeight: 700, marginBottom: 16, color: '#3f352e' },
  table: { width: '100%', borderCollapse: 'collapse', fontSize: 14, color: '#4b433d' },
  select: { width: '100%', padding: '8px 10px', borderRadius: 10, border: '1px solid #c6b8a7', background: '#fff', outline: 'none' },
  loading: { padding: 28, color: '#6e5f52' },
};
