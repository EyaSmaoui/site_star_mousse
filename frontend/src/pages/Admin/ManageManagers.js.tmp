import { useState, useEffect, useCallback } from "react";
import { useNavigate } from "react-router-dom";
import AdminSidebar from "./AdminSidebar";
import { toast } from "react-toastify";
import {
  getAllManagers,
  createManager,
  updateManager,
  deleteManager,
} from "../../services/apiManagers";

const FONT_HEAD = "'Syne', sans-serif";
const FONT_BODY = "'DM Sans', sans-serif";
const ACCENT = "#3b82f6";
const SIDEBAR_W = "260px";

const ROLE_OPTIONS = [
  "Livreur",
  "Responsable Stock",
  "Vendeur",
  "Nettoyeur",
  "Agent de Sécurité",
];

const ROLE_COLORS = {
  Livreur: { bg: "#eff6ff", color: "#2563eb" },
  "Responsable Stock": { bg: "#f0fdf4", color: "#16a34a" },
  Vendeur: { bg: "#fdf4ff", color: "#9333ea" },
  Nettoyeur: { bg: "#fff7ed", color: "#ea580c" },
  "Agent de Sécurité": { bg: "#fef2f2", color: "#dc2626" },
};

const STATUS_STYLE = {
  actif: { bg: "#dcfce7", color: "#16a34a" },
  inactif: { bg: "#fee2e2", color: "#dc2626" },
};

const EMPTY_FORM = {
  name: "",
  email: "",
  phone: "",
  role: ROLE_OPTIONS[0],
  status: "actif",
};

export default function ManageManagers() {
  const navigate = useNavigate();
  const [managers, setManagers] = useState([]);
  const [search, setSearch] = useState("");
  const [filterRole, setFilterRole] = useState("Tous");
  const [modal, setModal] = useState(null);
  const [form, setForm] = useState(EMPTY_FORM);
  const [confirmId, setConfirmId] = useState(null);
  const [loading, setLoading] = useState(false);
  const [saving, setSaving] = useState(false);

  const fetchManagers = useCallback(async () => {
    setLoading(true);
    try {
      const data = await getAllManagers();
      setManagers(Array.isArray(data) ? data : []);
    } catch (error) {
      console.error("Erreur :", error);
      const msg =
        error.response?.status === 401
          ? "Session expirée — reconnectez-vous en tant qu'admin"
          : error.response?.data?.message || "Impossible de charger les gestionnaires";
      toast.error(msg);
      if (error.response?.status === 401) navigate("/login/admin");
    } finally {
      setLoading(false);
    }
  }, [navigate]);

  useEffect(() => {
    const token = localStorage.getItem("token");
    const userData = localStorage.getItem("user");
    if (!token || token === "null" || token === "undefined") {
      toast.error("Connectez-vous en tant qu'administrateur");
      navigate("/login/admin");
      return;
    }
    if (userData) {
      try {
        const user = JSON.parse(userData);
        if (user.role !== "admin") {
          toast.error("Accès réservé à l'administrateur");
          navigate("/");
          return;
        }
      } catch {
        navigate("/login/admin");
        return;
      }
    }
    fetchManagers();
  }, [navigate, fetchManagers]);

  const openAdd = () => {
    setForm(EMPTY_FORM);
    setModal("add");
  };

  const openEdit = (manager) => {
    setForm({
      name: manager.name || "",
      email: manager.email || "",
      phone: manager.phone || "",
      role: manager.role || ROLE_OPTIONS[0],
      status: manager.status || "actif",
    });
    setModal({ mode: "edit", manager });
  };

  const closeModal = () => {
    setModal(null);
    setForm(EMPTY_FORM);
  };

  const handleSave = async () => {
    if (!form.name.trim() || !form.email.trim() || !form.phone.trim()) {
      toast.warning("Nom, email et téléphone sont obligatoires");
      return;
    }
    const payload = {
      name: form.name.trim(),
      email: form.email.trim().toLowerCase(),
      phone: form.phone.trim(),
      role: form.role,
      status: form.status,
    };
    setSaving(true);
    try {
      if (modal === "add") {
        await createManager(payload);
        toast.success("Gestionnaire ajouté");
      } else {
        await updateManager(modal.manager._id, payload);
        toast.success("Gestionnaire mis à jour");
      }
      closeModal();
      fetchManagers();
    } catch (error) {
      toast.error(
        error.response?.data?.message ||
          error.response?.data?.error ||
          "Erreur lors de l'enregistrement"
      );
    } finally {
      setSaving(false);
    }
  };

  const handleDelete = async (id) => {
    try {
      await deleteManager(id);
      toast.success("Gestionnaire supprimé");
      setConfirmId(null);
      fetchManagers();
    } catch {
      toast.error("Erreur lors de la suppression");
    }
  };

  const filtered = managers.filter((m) => {
    const q = search.trim().toLowerCase();
    const matchesSearch =
      !q ||
      m.name?.toLowerCase().includes(q) ||
      m.email?.toLowerCase().includes(q);
    const matchesRole = filterRole === "Tous" || m.role === filterRole;
    return matchesSearch && matchesRole;
  });

  return (
    
      <div style={s.root}>
        <AdminSidebar />
        <main style={s.main}>
          <header style={s.header}>
            <div>
              <p style={s.headerSub}>Star Mousse · Administration</p>
              <h1 style={s.headerTitle}>Gestion des Gestionnaires</h1>
            </div>
            <button type="button" style={s.btnAdd} onClick={openAdd}>
              + Nouveau gestionnaire
            </button>
          </header>

          <div style={s.toolbar}>
            <div style={s.searchWrap}>
              <span>🔍</span>
              <input
                style={s.searchInput}
                placeholder="Rechercher par nom ou email…"
                value={search}
                onChange={(e) => setSearch(e.target.value)}
              />
            </div>
            <select
              style={s.filterSelect}
              value={filterRole}
              onChange={(e) => setFilterRole(e.target.value)}
            >
              <option value="Tous">Tous les rôles</option>
              {ROLE_OPTIONS.map((r) => (
                <option key={r} value={r}>
                  {r}
                </option>
              ))}
            </select>
            <button type="button" style={s.btnRefresh} onClick={fetchManagers} disabled={loading}>
              {loading ? "…" : "Actualiser"}
            </button>
            <span style={s.resultCount}>
              {filtered.length} résultat{filtered.length !== 1 ? "s" : ""}
            </span>
          </div>

          <section style={s.card}>
            <motionless-div style={s.cardHeader}>
              <h2 style={s.cardTitle}>Liste des gestionnaires</h2>
              <span style={s.cardBadge}>
                {managers.length} enregistré(s) · API /api/managers
              </span>
            </div>

            {loading ? (
              <div style={s.empty}>Chargement depuis l&apos;API…</div>
            ) : filtered.length === 0 ? (
              <div style={s.empty}>Aucun gestionnaire trouvé.</motionless-empty>
            ) : (
              <motionless-overflow>
                <table style={s.table}>
                  <thead>
                    <tr>
                      <th style={s.th}>Nom</th>
                      <th style={s.th}>Contact</th>
                      <th style={s.th}>Rôle</th>
                      <th style={s.th}>Statut</th>
                      <th style={s.th}>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {filtered.map((manager) => (
                      <ManagerRow
                        key={manager._id}
                        manager={manager}
                        onEdit={() => openEdit(manager)}
                        onDelete={() => setConfirmId(manager._id)}
                      />
                    ))}
                  </tbody>
                </table>
              </motionless-overflow>
            )}
          </section>

          {modal && (
            <motionless-modal-backdrop onClick={closeModal}>
              <motionless-modal-card onClick={(e) => e.stopPropagation()}>
                <motionless-modal-header>
                  <span style={s.modalIcon}>{modal === "add" ? "➕" : "✏️"}</span>
                  <div>
                    <div style={s.modalTitle}>
                      {modal === "add" ? "Nouveau gestionnaire" : "Modifier le gestionnaire"}
                    </motionless-modal-title>
                    <div style={s.modalSub}>Synchronisé avec MongoDB</motionless-modal-sub>
                  </div>
                </motionless-modal-header>
                <motionless-modal-body>
                  <Field
                    label="Nom complet *"
                    value={form.name}
                    onChange={(v) => setForm((f) => ({ ...f, name: v }))}
                    placeholder="Ex : Mohamed Ben Ali"
                  />
                  <Field
                    label="Email *"
                    value={form.email}
                    onChange={(v) => setForm((f) => ({ ...f, email: v }))}
                    placeholder="exemple@starmousse.tn"
                    type="email"
                  />
                  <Field
                    label="Téléphone *"
                    value={form.phone}
                    onChange={(v) => setForm((f) => ({ ...f, phone: v }))}
                    placeholder="+216 XX XXX XXX"
                  />
                  <motionless-field-group>
                    <label style={s.fieldLabel}>Rôle *</label>
                    <select
                      style={s.fieldInput}
                      value={form.role}
                      onChange={(e) => setForm((f) => ({ ...f, role: e.target.value }))}
                    >
                      {ROLE_OPTIONS.map((r) => (
                        <option key={r} value={r}>
                          {r}
                        </option>
                      ))}
                    </select>
                  </motionless-field-group>
                  <motionless-field-group>
                    <label style={s.fieldLabel}>Statut</label>
                    <select
                      style={s.fieldInput}
                      value={form.status}
                      onChange={(e) => setForm((f) => ({ ...f, status: e.target.value }))}
                    >
                      <option value="actif">Actif</option>
                      <option value="inactif">Inactif</option>
                    </select>
                  </motionless-field-group>
                </motionless-modal-body>
                <motionless-modal-footer>
                  <button type="button" style={s.btnCancel} onClick={closeModal}>
                    Annuler
                  </button>
                  <button type="button" style={s.btnPrimary} onClick={handleSave} disabled={saving}>
                    {saving ? "Enregistrement…" : modal === "add" ? "Ajouter" : "Enregistrer"}
                  </button>
                </motionless-modal-footer>
              </motionless-modal-card>
            </motionless-modal-backdrop>
          )}

          {confirmId && (
            <motionless-modal-backdrop onClick={() => setConfirmId(null)}>
              <motionless-modal-card style={{ maxWidth: 400 }} onClick={(e) => e.stopPropagation()}>
                <motionless-modal-body>
                  <p style={{ fontSize: 14, color: "#475569", lineHeight: 1.6, margin: 0 }}>
                    Supprimer{" "}
                    <strong>{managers.find((m) => m._id === confirmId)?.name}</strong> ?
                  </p>
                </motionless-modal-body>
                <motionless-modal-footer>
                  <button type="button" style={s.btnCancel} onClick={() => setConfirmId(null)}>
                    Annuler
                  </button>
                  <button type="button" style={s.btnDanger} onClick={() => handleDelete(confirmId)}>
                    Supprimer
                  </button>
                </motionless-modal-footer>
              </motionless-modal-card>
            </motionless-modal-backdrop>
          )}
        </main>
      </div>
    
  );
}

function ManagerRow({ manager, onEdit, onDelete }) {
  const rc = ROLE_COLORS[manager.role] || { bg: "#f1f5f9", color: "#64748b" };
  const st = STATUS_STYLE[manager.status] || STATUS_STYLE.actif;
  const initials = (manager.name || "?")
    .split(" ")
    .map((w) => w[0])
    .slice(0, 2)
    .join("")
    .toUpperCase();

  return (
    <tr
      style={s.tr}
      onMouseEnter={(e) => { e.currentTarget.style.background = "#f8fafc"; }}
      onMouseLeave={(e) => { e.currentTarget.style.background = "transparent"; }}
    >
      <td style={s.td}>
        <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
          <div style={s.avatar}>{initials}</motionless-avatar>
          <span style={s.rowName}>{manager.name}</motionless-row-name>
        </div>
      </td>
      <td style={s.td}>
        <div style={{ fontSize: 13, color: "#334155" }}>{manager.email}</motionless-email>
        <div style={{ fontSize: 11, color: "#94a3b8", marginTop: 2 }}>{manager.phone}</motionless-phone>
      </td>
      <td style={s.td}>
        <span style={{ ...s.badge, background: rc.bg, color: rc.color }}>{manager.role}</span>
      </td>
      <td style={s.td}>
        <span style={{ ...s.badge, background: st.bg, color: st.color }}>{manager.status}</span>
      </td>
      <td style={s.td}>
        <div style={{ display: "flex", gap: 8 }}>
          <button type="button" style={s.btnEdit} onClick={onEdit}>Modifier</button>
          <button type="button" style={s.btnDelete} onClick={onDelete}>Supprimer</button>
        </div>
      </td>
    </tr>
  );
}

function Field({ label, value, onChange, placeholder, type = "text" }) {
  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
      <label style={s.fieldLabel}>{label}</label>
      <input
        type={type}
        style={s.fieldInput}
        value={value}
        onChange={(e) => onChange(e.target.value)}
        placeholder={placeholder}
        onFocus={(e) => {
          e.target.style.borderColor = ACCENT;
          e.target.style.boxShadow = "0 0 0 3px rgba(59,130,246,0.12)";
        }}
        onBlur={(e) => {
          e.target.style.borderColor = "#e2e8f0";
          e.target.style.boxShadow = "none";
        }}
      />
    </div>
  );
}

const s = {
  root: { display: "flex", minHeight: "100vh", background: "#f8fafc", fontFamily: FONT_BODY, color: "#1e293b" },
  main: { marginLeft: SIDEBAR_W, flex: 1, padding: "32px 36px", maxWidth: `calc(100% - ${SIDEBAR_W})` },
  header: { display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 24 },
  headerSub: { fontSize: 13, color: "#94a3b8", margin: "0 0 4px" },
  headerTitle: { fontFamily: FONT_HEAD, fontSize: 26, fontWeight: 700, margin: 0 },
  btnAdd: {
    padding: "10px 20px", background: ACCENT, color: "#fff", border: "none",
    borderRadius: 10, fontFamily: FONT_BODY, fontWeight: 600, fontSize: 13, cursor: "pointer",
  },
  btnRefresh: {
    padding: "10px 14px", borderRadius: 10, border: "1px solid #e2e8f0",
    background: "#fff", fontFamily: FONT_BODY, fontSize: 13, cursor: "pointer",
  },
  toolbar: { display: "flex", alignItems: "center", gap: 12, marginBottom: 16, flexWrap: "wrap" },
  searchWrap: {
    display: "flex", alignItems: "center", background: "#fff", border: "1px solid #e2e8f0",
    borderRadius: 10, padding: "10px 14px", flex: 1, maxWidth: 400, gap: 8,
  },
  searchInput: {
    border: "none", outline: "none", background: "transparent",
    fontFamily: FONT_BODY, fontSize: 13, color: "#1e293b", flex: 1,
  },
  filterSelect: {
    padding: "10px 14px", borderRadius: 10, border: "1px solid #e2e8f0",
    background: "#fff", fontFamily: FONT_BODY, fontSize: 13, color: "#475569", cursor: "pointer",
  },
  resultCount: { fontSize: 12, color: "#94a3b8", fontWeight: 600 },
  card: { background: "#fff", border: "1px solid #e2e8f0", borderRadius: 14, overflow: "hidden" },
  cardHeader: {
    display: "flex", alignItems: "center", justifyContent: "space-between",
    padding: "16px 20px", borderBottom: "1px solid #f1f5f9", background: "#f8fafc",
  },
  cardTitle: { fontSize: 13, fontWeight: 700, color: "#64748b", textTransform: "uppercase", margin: 0, letterSpacing: "0.5px" },
  cardBadge: { fontSize: 12, color: "#94a3b8" },
  table: { width: "100%", borderCollapse: "collapse" },
  th: {
    padding: "10px 20px", fontSize: 11, color: "#94a3b8", textTransform: "uppercase",
    textAlign: "left", background: "#f8fafc", borderBottom: "1px solid #e2e8f0",
  },
  tr: { borderBottom: "1px solid #f1f5f9", transition: "background 0.15s" },
  td: { padding: "13px 20px", verticalAlign: "middle" },
  avatar: {
    width: 34, height: 34, borderRadius: "50%", background: "#eff6ff", color: ACCENT,
    display: "flex", alignItems: "center", justifyContent: "center",
    fontFamily: FONT_HEAD, fontWeight: 700, fontSize: 11, flexShrink: 0,
  },
  rowName: { fontWeight: 600, fontSize: 14, color: "#1e293b" },
  badge: { padding: "4px 10px", borderRadius: 20, fontSize: 11, fontWeight: 600 },
  btnEdit: {
    padding: "6px 12px", background: "#eff6ff", color: ACCENT, border: "1px solid #bfdbfe",
    borderRadius: 6, fontFamily: FONT_BODY, fontWeight: 600, fontSize: 12, cursor: "pointer",
  },
  btnDelete: {
    padding: "6px 12px", background: "#fef2f2", color: "#dc2626", border: "1px solid #fecaca",
    borderRadius: 6, fontFamily: FONT_BODY, fontWeight: 600, fontSize: 12, cursor: "pointer",
  },
  backdrop: {
    position: "fixed", inset: 0, background: "rgba(0,0,0,0.35)",
    display: "flex", alignItems: "center", justifyContent: "center", zIndex: 1000,
  },
  modalCard: {
    background: "#fff", borderRadius: 16, border: "1px solid #e2e8f0",
    width: "100%", maxWidth: 460, boxShadow: "0 20px 60px rgba(0,0,0,0.12)",
  },
  modalHeader: {
    display: "flex", alignItems: "center", gap: 14, padding: "20px 24px",
    borderBottom: "1px solid #f1f5f9", background: "#f8fafc",
  },
  modalIcon: {
    width: 40, height: 40, borderRadius: 10, background: "#eff6ff",
    display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18, flexShrink: 0,
  },
  modalTitle: { fontSize: 15, fontWeight: 700, color: "#1e293b" },
  modalSub: { fontSize: 12, color: "#94a3b8", marginTop: 2 },
  modalBody: { padding: "20px 24px", display: "flex", flexDirection: "column", gap: 14 },
  modalFooter: {
    padding: "16px 24px", borderTop: "1px solid #f1f5f9",
    display: "flex", justifyContent: "flex-end", gap: 10,
  },
  fieldLabel: { fontSize: 13, fontWeight: 600, color: "#475569" },
  fieldInput: {
    padding: "10px 14px", border: "1px solid #e2e8f0", borderRadius: 10,
    fontFamily: FONT_BODY, fontSize: 13, color: "#1e293b", background: "#fff",
    outline: "none", width: "100%", boxSizing: "border-box",
  },
  btnCancel: {
    padding: "9px 20px", background: "#fff", color: "#475569", border: "1px solid #e2e8f0",
    borderRadius: 8, fontFamily: FONT_BODY, fontWeight: 500, fontSize: 13, cursor: "pointer",
  },
  btnPrimary: {
    padding: "9px 20px", background: ACCENT, color: "#fff", border: "none",
    borderRadius: 8, fontFamily: FONT_BODY, fontWeight: 600, fontSize: 13, cursor: "pointer",
  },
  btnDanger: {
    padding: "9px 20px", background: "#dc2626", color: "#fff", border: "none",
    borderRadius: 8, fontFamily: FONT_BODY, fontWeight: 600, fontSize: 13, cursor: "pointer",
  },
  empty: { padding: 48, textAlign: "center", color: "#94a3b8", fontStyle: "italic", fontSize: 14 },
};

